# Copy to .env and fill in. Never commit .env.
# Compose project name is fixed via top-level `name: shillscore` in docker-compose.yml,
# so this stack is isolated from twitter-digest even on a shared host.

# --- Postgres ---
POSTGRES_DB=shillscore
POSTGRES_USER=shillscore
POSTGRES_PASSWORD=                # generate: openssl rand -hex 24

# --- Public surface ---
PUBLIC_HOSTNAME=shillscore.tg-itsavibe.com

# --- X / Twitter (OAuth 2.0 PKCE; pay-per-use credit account) ---
# Mint a fresh OAuth 2.0 app for shillscore — do NOT reuse the twitter-digest creds.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://shillscore.tg-itsavibe.com/auth/twitter/callback

# --- GitHub OAuth (secondary, optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://shillscore.tg-itsavibe.com/auth/github/callback

# --- Price sources ---
COINGECKO_API_KEY=                # optional; leave empty to use the free public endpoint
DEFILLAMA_BASE_URL=https://coins.llama.fi

# --- Session / cookie signing ---
SESSION_SECRET=                   # generate: openssl rand -hex 32

# --- Logging ---
LOG_LEVEL=INFO
